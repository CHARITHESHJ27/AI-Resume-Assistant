# ── Provider Selection ─────────────────────────────────────────────────────────
# Options: "ollama" (default, free/local) | "openai" | "gemini"
LLM_PROVIDER=ollama

# ── Ollama (default — free, runs locally, no API key needed) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI (optional — uncomment + set key, then set LLM_PROVIDER=openai) ──────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Gemini (optional — uncomment + set key, then set LLM_PROVIDER=gemini) ──────
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash

# ── Embeddings (always local/free via HuggingFace — no key needed) ─────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage ────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./vector_store/chroma_db
CORS_ORIGINS=http://localhost:3000
